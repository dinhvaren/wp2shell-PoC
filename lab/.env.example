# wp2shell Docker Lab
# Copy this file to .env and adjust as needed

# WordPress Admin (for local lab only)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=wp2shell-local-lab
WP_ADMIN_EMAIL=admin@localhost.local

# Site
WP_SITE_TITLE=wp2shell Lab

# Vulnerable instance -> http://127.0.0.1:8081
# Fixed instance      -> http://127.0.0.1:8082
